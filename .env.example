# Runtime environment: production, staging, development, or test.
APP_ENV=development
NODE_ENV=development

# Supabase PostgreSQL connection string. Production and Staging must use
# different databases. Never commit a real connection string.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@HOST:6543/postgres?sslmode=require

# UI diagnostics and server logging.
DEBUG_PANEL_DEFAULT=false
LOG_LEVEL=info

# Optional connection-pool tuning.
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000

# The cloud platform normally provides PORT in production.
PORT=4173
