# Runtime environment: production, staging, development, or test.
APP_ENV=development
NODE_ENV=development

# Supabase PostgreSQL connection string. Production and Staging must use
# different databases. Never commit a real connection string.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@HOST:6543/postgres?sslmode=require

# UI diagnostics and server logging.
DEBUG_PANEL_DEFAULT=false
LOG_LEVEL=info

# Temporary safety gate for public market-data maintenance. Writes are allowed
# only when APP_ENV=staging and this value is explicitly true. Production
# always rejects Editor writes, even if this variable is accidentally enabled.
EDITOR_WRITE_ENABLED=false

# Supabase Auth public client configuration. Use both values from the same
# project as DATABASE_URL. Never use a service-role or secret key here.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Production-only Journal migration safety allow-list. The project ref must
# match DATABASE_URL exactly. The confirmation value is required only for the
# formal migration command; never set it globally or in a browser environment.
PRODUCTION_SUPABASE_PROJECT_REF=
PRODUCTION_JOURNAL_MIGRATION_CONFIRM=

# Required Staging deny-list evidence used by the Production migration runner.
# The project ref is mandatory. Optional URL/database evidence, when supplied,
# must resolve to the same Staging ref or the runner fails closed.
STAGING_SUPABASE_PROJECT_REF=
STAGING_DATABASE_PROJECT_REF=
STAGING_SUPABASE_URL=
STAGING_DATABASE_URL=

# Optional connection-pool tuning.
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000

# The cloud platform normally provides PORT in production.
PORT=4173
