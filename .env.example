# Runtime environment: production, staging, development, or test.
APP_ENV=development
NODE_ENV=development

# Supabase PostgreSQL connection string. Production and Staging must use
# different databases. Never commit a real connection string.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@HOST:6543/postgres?sslmode=require

# UI diagnostics and server logging.
DEBUG_PANEL_DEFAULT=false
LOG_LEVEL=info

# Optional release metadata. Render supplies RENDER_GIT_COMMIT automatically;
# APP_VERSION defaults to package.json and DEPLOYED_AT defaults to null.
APP_VERSION=1.0.0
DEPLOYED_AT=

# Required only for protected Staging seed commands. Must equal the project
# identifier embedded in the Staging DATABASE_URL username.
STAGING_DATABASE_PROJECT_REF=
STAGING_SEED_CONFIRM=

# Dedicated remote acceptance guard. The runner refuses to write unless both
# APP_ENV and this value equal staging. Never point this URL at Production.
STAGING_ACCEPTANCE_CONFIRM=
STAGING_BASE_URL=
STAGING_EXPECTED_INDICATORS=10
STAGING_EXPECTED_EVENTS=2
STAGING_ACCEPTANCE_TIMEOUT_MS=30000

# Required only by the dedicated Staging Journal RLS migration runner. The
# owner UUID is supplied as a parameter and must never be committed with a real
# value. A Production project identifier is required as an additional deny-list
# guard before the Journal RLS runner will connect.
JOURNAL_LEGACY_OWNER_USER_ID=
PRODUCTION_DATABASE_PROJECT_REF=

# Optional extra deny-list used by the Staging acceptance runner.
PRODUCTION_BASE_URL=

# Temporary safety gate for public market-data maintenance. Writes are allowed
# only when APP_ENV=staging and this value is explicitly true. Production
# always rejects Editor writes, even if this variable is accidentally enabled.
EDITOR_WRITE_ENABLED=false

# Supabase Auth and Journal Data API public configuration. The Publishable Key
# identifies the project; user identity comes from a verified Access Token.
# Legacy anon keys remain compatible. Never use service-role or secret keys here.
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Optional connection-pool tuning.
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000

# The cloud platform normally provides PORT in production.
PORT=4173
