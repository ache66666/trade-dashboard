# Staging-only template. Copy to .env.staging.local, which is ignored by Git.
APP_ENV=staging
NODE_ENV=production

# Required Secret: Staging PostgreSQL connection. Never reuse Production.
DATABASE_URL=

# Required public project configuration. The Publishable Key is not identity;
# user identity comes from a verified Access Token. Never use service_role.
SUPABASE_URL=https://STAGING_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Public-data Editor remains disabled unless a separate authorized test says otherwise.
EDITOR_WRITE_ENABLED=false
DEBUG_PANEL_DEFAULT=false
LOG_LEVEL=info

# Seed and migration safety guards.
STAGING_DATABASE_PROJECT_REF=
STAGING_SEED_CONFIRM=staging
PRODUCTION_DATABASE_PROJECT_REF=
JOURNAL_LEGACY_OWNER_USER_ID=

# Automated Staging acceptance. Credentials are Secrets and must only identify
# disposable Staging test users. The runner creates temporary User B data and cleans it.
STAGING_ACCEPTANCE_CONFIRM=staging
STAGING_BASE_URL=https://YOUR-STAGING-SERVICE.onrender.com
PRODUCTION_BASE_URL=https://YOUR-PRODUCTION-SERVICE.onrender.com
STAGING_EXPECTED_INDICATORS=10
STAGING_EXPECTED_EVENTS=2
STAGING_ACCEPTANCE_TIMEOUT_MS=30000
JOURNAL_TEST_USER_A_EMAIL=
JOURNAL_TEST_USER_A_PASSWORD=
JOURNAL_TEST_USER_B_EMAIL=
JOURNAL_TEST_USER_B_PASSWORD=
